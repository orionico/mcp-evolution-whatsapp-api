# Evolution API Configuration
EVOLUTION_API_URL=https://example.com/
EVOLUTION_API_KEY=YOUR_API_KEY_HERE
EVOLUTION_DEFAULT_INSTANCE=

# HTTP transport (only needed when MCP_TRANSPORT=http, e.g. remote deployment)
MCP_TRANSPORT=stdio
PORT=3000
MCP_PATH=/mcp-evolution-whatsapp-api
MCP_HTTP_AUTH_TOKEN=
